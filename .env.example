# ============================================================
# Copy this file to .env and edit values:
#   copy .env.example .env
#
# .env is gitignored — never commit real phone/login secrets.
# ============================================================

# WhatsApp account phone (session folder label)
# Example: 7905975835 → 917905975835 (India +91)
WA_PHONE=917905975835

# Optional: force session folder name (defaults to WA_PHONE)
# WA_CLIENT_ID=

# false = show browser (needed first time for QR / ChatGPT login)
WA_HEADLESS=false
GPT_HEADLESS=false

# true = send ChatGPT answer on WhatsApp automatically
AUTO_REPLY=true

# How often to check WhatsApp for new messages (seconds)
POLL_INTERVAL_SEC=2.5

# true = also reply in group chats (default: personal DMs only)
ALLOW_GROUP_MESSAGES=false
